{
  "control": {
    "version": 4,
    "online": true,
    "state_file": "./model/mortal.pth",
    "best_state_file": "./model/best.pth",
    "tensorboard_dir": "/root/tf-logs",
    "device": "cuda:0",
    "enable_cudnn_benchmark": false,
    "enable_amp": false,
    "enable_compile": false,
    "batch_size": 512,
    "opt_step_every": 1,
    "save_every": 40,
    "test_every": 40000,
    "submit_every": 40,
    "old_update_every": 40
  },
  "train_play": {
    "default": {
      "games": 80,
      "log_dir": "./train_play",
      "repeats": 1
    }
  },
  "test_play": {
    "games": 4000,
    "log_dir": "./test_play"
  },
  "dataset": {
    "globs": [
      "./out/**/*.json.gz"
    ],
    "file_index": "./file_index.pth",
    "file_batch_size": 1,
    "reserve_ratio": 0.0,
    "num_workers": 32,
    "player_names_files": [],
    "num_epochs": 1,
    "enable_augmentation": false,
    "augmented_first": false
  },
  "resnet": {
    "conv_channels": 192,
    "num_blocks": 40
  },
  "env": {
    "pts": [
      3.0,
      1.5,
      0.0,
      -4.5
    ]
  },
  "policy": {
    "awr_beta": 0.75,
    "awr_clip": 75,
    "entropy_weight": 0.001,
    "clip_ratio": 0.2,
    "dual_clip": 3.0
  },
  "optim": {
    "eps": 1e-08,
    "betas": [
      0.9,
      0.999
    ],
    "weight_decay": 0.1,
    "max_grad_norm": 5,
    "scheduler": {
      "peak": 1e-06,
      "final": 1e-06,
      "warm_up_steps": 0,
      "max_steps": 0
    }
  },
  "baseline": {
    "train": {
      "device": "cuda:0",
      "enable_compile": false,
      "state_file": "./model/mortal_ot_pt2.pth"
    },
    "test": {
      "device": "cuda:0",
      "enable_compile": false,
      "state_file": "./model/baseline.pth"
    }
  },
  "online": {
    "history_window": 50,
    "enable_compile": false,
    "remote": {
      "host": "127.0.0.1",
      "port": 5000
    },
    "server": {
      "buffer_dir": "./buffer",
      "drain_dir": "./drain",
      "sample_reuse_rate": 0,
      "sample_reuse_threshold": 0,
      "capacity": 400,
      "force_sequential": false
    }
  },
  "1v3": {
    "seed_key": -1,
    "games_per_iter": 2000,
    "iters": 10,
    "log_dir": "./1v3",
    "challenger": {
      "device": "cuda:0",
      "name": "mortal",
      "state_file": "./model/best.pth",
      "stochastic_latent": false,
      "enable_compile": false,
      "enable_amp": false,
      "enable_rule_based_agari_guard": true
    },
    "champion": {
      "device": "cuda:0",
      "name": "baseline",
      "state_file": "./model/mortal.pth",
      "stochastic_latent": false,
      "enable_compile": false,
      "enable_amp": false,
      "enable_rule_based_agari_guard": true
    },
    "akochan": {
      "enabled": false,
      "dir": "/path/to/akochan",
      "tactics": "/path/to/tactics.json"
    }
  },
  "grp": {
    "state_file": "./model/grp_240000.pth",
    "network": {
      "hidden_size": 64,
      "num_layers": 2
    },
    "control": {
      "device": "cuda:0",
      "enable_cudnn_benchmark": false,
      "tensorboard_dir": "/root/tf-logs",
      "batch_size": 512,
      "save_every": 2000,
      "val_steps": 400
    },
    "dataset": {
      "train_globs": [
        "./out/2010/*.json.gz",
        "./out/2011/*.json.gz",
        "./out/2012/*.json.gz",
        "./out/2014/*.json.gz",
        "./out/2016/*.json.gz",
        "./out/2018/*.json.gz",
        "./out/2019/*.json.gz",
        "./out/2020/*.json.gz",
        "./out/2021/*.json.gz",
        "./out/2022/*.json.gz",
        "./out/2023/*.json.gz",
        "./out/2024/*.json.gz"
      ],
      "val_globs": [
        "./out/2013/*.json.gz",
        "./out/2015/*.json.gz",
        "./out/2017/*.json.gz"
      ],
      "file_index": "./grp_file_index.pth",
      "file_batch_size": 50
    },
    "optim": {
      "lr": 1e-05
    }
  }
}